{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reducer-state.schema.json",
  "title": "ReducerState",
  "description": "State snapshot for the review reducer, tracking progress across review groups.",
  "type": "object",
  "required": ["schema_version", "state_kind", "source", "status", "manifest_units", "review_groups", "reviewed_units", "pending_units", "needs_split_units", "group_results", "coverage_gaps", "finding_merge", "dependency_checks", "test_recommendations", "final_verdict", "persistence_rule"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "state_kind": { "type": "string", "const": "review_reducer" },
    "source": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "in_progress", "complete"] },
    "manifest_units": { "type": "integer", "minimum": 0 },
    "review_groups": { "type": "integer", "minimum": 0 },
    "reviewed_units": { "type": "array" },
    "pending_units": { "type": "array", "items": { "type": "string" } },
    "needs_split_units": { "type": "array", "items": { "type": "string" } },
    "group_results": { "type": "array" },
    "coverage_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "group_id", "risk_tags", "coverage_status"],
        "properties": {
          "unit_id": { "type": "string" },
          "group_id": { "type": "string" },
          "risk_tags": { "type": "string" },
          "coverage_status": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "finding_merge": {
      "type": "object",
      "required": ["deduplicated_findings", "blockers", "notes"],
      "properties": {
        "deduplicated_findings": { "type": "array" },
        "blockers": { "type": "array" },
        "notes": { "type": "array" }
      },
      "additionalProperties": false
    },
    "dependency_checks": { "type": "array" },
    "test_recommendations": { "type": "array" },
    "final_verdict": { "type": "string" },
    "persistence_rule": { "type": "string" }
  },
  "additionalProperties": false
}
